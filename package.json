{
  "name": "@gerundium/agentops-forge",
  "version": "0.2.0",
  "description": "Professional TypeScript toolkit for autonomous multi-agent operations",
  "main": "dist/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup src/index.ts src/cli.ts src/server.ts --dts --format esm,cjs --clean",
